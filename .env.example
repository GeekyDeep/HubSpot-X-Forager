# Forager.ai credentials
# Get these from: https://app.forager.ai → Settings → API Keys
FORAGER_API_KEY=your_forager_api_key_here
FORAGER_ACCOUNT_ID=your_forager_account_id_here

# HubSpot Private App Access Token
# Create at: HubSpot → Settings → Integrations → Private Apps
# Required scopes: crm.objects.contacts.write, crm.objects.companies.write,
#                  crm.objects.contacts.read, crm.objects.companies.read
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token_here

# Optional: HubSpot webhook signing secret (for signature validation)
# Get from: HubSpot → Settings → Integrations → Webhooks
HUBSPOT_CLIENT_SECRET=your_hubspot_client_secret_here
